{
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "eval": {
        "target": {
          "installable": ".#darwinConfigurations.legendre.config.system.build.toplevel"
        }
      },
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"${workspaceFolder}\").inputs.nixpkgs { system = builtins.currentSystem; config.allowUnfree = true; }"
      },
      "formatting": {
        "command": [
          "nixfmt"
        ]
      },
      "options": {
        "home-manager-ubuntu-dev": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").homeConfigurations.ubuntu-dev.options"
        },
        "home-manager-legendre": {
          "expr": "((builtins.getFlake \"${workspaceFolder}\").darwinConfigurations.legendre.options.home-manager.users.type.getSubOptions [])"
        },
        "nix-darwin": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").darwinConfigurations.legendre.options"
        }
      }
    }
  }
}